# Copy to .env for local dev (do NOT commit the real .env).
# In production these are set in the Render dashboard, not in a file.

# --- Database (required in production) ---
# Neon Postgres POOLED connection string. Get it from the Neon console:
#   Project -> Connect -> "Pooled connection" (host ends in -pooler...).
# The pooled endpoint is what you want for a web service (many short connections).
# Keep sslmode=require. If unset, the app falls back to an EPHEMERAL in-memory
# store (dev only — data is lost on restart) and logs a WARNING.
DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require

# --- Per-IP rate limiting (optional; sliding window, in-memory) ---
# Resets on restart/scale. Requests over the cap get HTTP 429.
RATE_LIMIT_PER_MIN=30
RATE_LIMIT_PER_DAY=300
